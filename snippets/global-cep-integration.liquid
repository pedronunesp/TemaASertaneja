{% comment %}
  Global CEP Integration - Integração com calculadora de frete
  
  Uso:
  {%- render 'global-cep-integration' -%}
  
  Este snippet fornece funções para integrar o CEP global com calculadoras de frete
  ou outros componentes que precisam do CEP do cliente.
{% endcomment %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Selectors for VisionFrete (Product/Cart pages)
    const visionInput = document.getElementById('campo-cep');
    const visionButton = document.querySelector('.buscaCep');
    
    // Selectors for other calculators (generic fallback)
    const genericInput = document.getElementById('cep-input');
    const genericButton = document.getElementById('calculate-freight-btn');

    const targetInput = visionInput || genericInput;
    const targetButton = visionButton || genericButton;
    
    if (targetInput) {
      // Retrieve saved CEP
      const savedCep = localStorage.getItem('shopify_customer_cep') || 
                       {% if cart.attributes.CEP %}
                         "{{ cart.attributes.CEP }}"
                       {% elsif cart.attributes.customer_cep %}
                         "{{ cart.attributes.customer_cep }}"
                       {% else %}
                         null
                       {% endif %};
                         
      if (savedCep) {
        // Fill input
        targetInput.value = savedCep.replace(/\D/g, ''); // Keep only numbers or format as needed
        
        // Format for VisionFrete (expects 00000-000 usually, but let's check mask)
        // visionfrete.liquid uses data-mask="00000-000" but logic handles raw input?
        // Let's trigger input event just in case
        targetInput.dispatchEvent(new Event('input', { bubbles: true }));
        
        // Optional: Auto-click button if on product page and we have a CEP
        // Only if it's visionButton to avoid loops or unwanted behavior
        if (visionButton && window.location.pathname.includes('/products/')) {
           // visionButton.click(); // Uncomment if auto-calculation is desired
        }
      }
      
      // Listen for calculation to update global state
      if (targetButton) {
        targetButton.addEventListener('click', function() {
          const cep = targetInput.value.replace(/\D/g, '');
          if (cep.length === 8) {
            const formattedCep = cep.replace(/(\d{5})(\d{3})/, '$1-$2');
            
            // Save to localStorage
            localStorage.setItem('shopify_customer_cep', formattedCep);
            
            // Dispatch event
            document.dispatchEvent(new CustomEvent('cep_updated', { 
              detail: { cep: formattedCep } 
            }));
            
            // Update Cart Attributes
            fetch('/cart/update.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                attributes: {
                  'CEP': formattedCep
                }
              })
            }).catch(e => console.warn(e));
          }
        });
      }
    }
    
    // Listen for global updates (e.g. from Header)
    document.addEventListener('cep_updated', function(e) {
      const newCep = e.detail.cep;
      if (newCep && targetInput) {
        targetInput.value = newCep;
        // Optionally trigger calculation
        // if (targetButton) targetButton.click();
      }
    });
  });
</script>
