{% comment %}
  Global CEP Field - Refatorado para melhor UX/UI
  Substitui a versão anterior complexa por uma abordagem mais limpa e modal.
{% endcomment %}

<style>
  /* Global Bar Styling (Parent Container) */
  .global-cep-bar {
    background-color: #f9f9f9;
    border-top: 1px solid #e5e5e5;
    padding: 8px 0;
    text-align: center;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .global-cep-component {
    position: relative;
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body-family, sans-serif);
  }

  /* Trigger Button (O que aparece no header) */
  .cep-trigger {
    display: flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 1px solid transparent;
    padding: 6px 12px;
    border-radius: 20px; /* Pill shape */
    cursor: pointer;
    color: var(--color-text, #333);
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .cep-trigger:hover {
    background-color: rgba(0, 0, 0, 0.05);
    border-color: rgba(0,0,0,0.1);
  }
  
  .cep-trigger svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--color-primary, #000); /* Use theme primary color if available */
  }

  .cep-text {
    white-space: nowrap;
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    font-weight: 500;
  }

  /* Modal / Popover */
  .cep-modal {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 8px;
    width: 300px;
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    padding: 20px;
    z-index: 1000;
    display: none; /* Hidden by default */
    border: 1px solid #eee;
    animation: fadeIn 0.2s ease-out;
  }

  .cep-modal.active {
    display: block;
  }

  /* Mobile adjustments for Modal */
  @media (max-width: 768px) {
    .cep-modal {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 90%;
      max-width: 320px;
      margin-top: 0;
    }
    
    .cep-backdrop {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.5);
      z-index: 999;
      display: none;
    }
    
    .cep-backdrop.active {
      display: block;
    }
  }

  .cep-modal h3 {
    margin: 0 0 8px 0;
    font-size: 1rem;
    color: #333;
    font-weight: 600;
  }

  .cep-modal p {
    margin: 0 0 15px 0;
    font-size: 0.85rem;
    color: #666;
    line-height: 1.4;
  }

  .cep-input-group {
    display: flex;
    gap: 8px;
    margin-bottom: 8px;
  }

  .cep-input {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .cep-input:focus {
    border-color: #333;
  }

  .cep-submit-btn {
    background-color: #333;
    color: #fff;
    border: none;
    border-radius: 4px;
    padding: 0 16px;
    cursor: pointer;
    font-weight: 600;
    transition: background-color 0.2s;
  }

  .cep-submit-btn:hover {
    background-color: #000;
  }
  
  .cep-submit-btn:disabled {
    background-color: #ccc;
    cursor: not-allowed;
  }

  .cep-error-msg {
    color: #e74c3c;
    font-size: 0.8rem;
    display: block;
    margin-bottom: 10px;
    min-height: 1.2em;
  }

  .cep-footer-links {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
  }

  .cep-link {
    color: #666;
    text-decoration: underline;
    cursor: pointer;
  }
  
  .cep-close-mobile {
    position: absolute;
    top: 10px;
    right: 10px;
    background: none;
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    color: #999;
    padding: 5px;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  /* Spinner */
  .cep-spinner {
    display: none;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255,255,255,0.3);
    border-radius: 50%;
    border-top-color: #fff;
    animation: spin 1s ease-in-out infinite;
  }
  
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  
  .cep-submit-btn.loading span {
    display: none;
  }
  
  .cep-submit-btn.loading .cep-spinner {
    display: inline-block;
  }
</style>

<div class="global-cep-component" id="global-cep-component">
  <div class="cep-backdrop" id="cep-backdrop"></div>

  <!-- Trigger Button -->
  <button class="cep-trigger" id="cep-trigger" aria-label="Alterar localização">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
      <circle cx="12" cy="10" r="3"></circle>
    </svg>
    <span class="cep-text" id="cep-display-text">Informe seu CEP</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 4px; opacity: 0.6;">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>

  <!-- Modal Content -->
  <div class="cep-modal" id="cep-modal">
    <button class="cep-close-mobile" id="cep-close-mobile" aria-label="Fechar">&times;</button>
    <h3>Onde você está?</h3>
    <p>Informe seu CEP para ver as melhores ofertas e prazos para sua região.</p>
    
    <div class="cep-input-group">
      <input type="tel" id="cep-input" class="cep-input" placeholder="00000-000" maxlength="9" autocomplete="postal-code">
      <button id="cep-submit" class="cep-submit-btn">
        <span>OK</span>
        <div class="cep-spinner"></div>
      </button>
    </div>
    
    <span id="cep-error" class="cep-error-msg"></span>
    
    <div class="cep-footer-links">
      <a href="https://buscacepinter.correios.com.br/app/endereco/index.php" target="_blank" rel="noopener noreferrer" class="cep-link">Não sei meu CEP</a>
      <button id="cep-clear" class="cep-link" style="background:none; border:none; padding:0; display:none;">Remover localização</button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const component = document.getElementById('global-cep-component');
    const trigger = document.getElementById('cep-trigger');
    const modal = document.getElementById('cep-modal');
    const backdrop = document.getElementById('cep-backdrop');
    const input = document.getElementById('cep-input');
    const submitBtn = document.getElementById('cep-submit');
    const errorMsg = document.getElementById('cep-error');
    const displayText = document.getElementById('cep-display-text');
    const closeMobile = document.getElementById('cep-close-mobile');
    const clearBtn = document.getElementById('cep-clear');

    // State
    let currentCep = localStorage.getItem('shopify_customer_cep') || '';
    let currentCity = localStorage.getItem('shopify_customer_city') || '';
    let currentState = localStorage.getItem('shopify_customer_state') || '';

    // --- Initialization ---
    function init() {
      if (currentCep && currentCity && currentState) {
        updateDisplay(currentCity, currentState);
        input.value = formatCep(currentCep);
        clearBtn.style.display = 'inline';
      } else if (currentCep) {
        // Caso tenha CEP mas não tenha cidade/estado (cache antigo ou incompleto), busca novamente
        fetchCepData(currentCep);
      }
    }

    // --- UI Functions ---
    function toggleModal(forceClose = false) {
      const isOpen = modal.classList.contains('active');
      if (isOpen || forceClose) {
        modal.classList.remove('active');
        backdrop.classList.remove('active');
      } else {
        modal.classList.add('active');
        backdrop.classList.add('active');
        setTimeout(() => input.focus(), 100); // Focus input when opening
      }
    }

    function updateDisplay(city, state) {
      if (city && state) {
        displayText.textContent = `${city}, ${state}`;
        displayText.title = `${city}, ${state}`; // Tooltip
        clearBtn.style.display = 'inline';
      } else {
        displayText.textContent = 'Informe seu CEP';
        displayText.title = 'Informe seu CEP';
        clearBtn.style.display = 'none';
      }
    }

    function showError(msg) {
      errorMsg.textContent = msg;
      input.classList.add('error');
    }

    function clearError() {
      errorMsg.textContent = '';
      input.classList.remove('error');
    }

    function setLoading(isLoading) {
      if (isLoading) {
        submitBtn.classList.add('loading');
        submitBtn.disabled = true;
      } else {
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
      }
    }

    // --- Logic Functions ---
    function formatCep(value) {
      return value.replace(/\D/g, '').replace(/^(\d{5})(\d)/, '$1-$2');
    }

    async function fetchCepData(cep, shouldDispatch = true) {
      const cleanCep = cep.replace(/\D/g, '');
      if (cleanCep.length !== 8) {
        showError('CEP incompleto.');
        return;
      }
      
      // Evita refetch se for o mesmo CEP e já tivermos dados (opcional, mas bom para performance)
      if (cleanCep === currentCep && currentCity && currentState) {
          return;
      }

      setLoading(true);
      clearError();

      try {
        // Verifica cache de sessão primeiro (reduz chamadas API)
        const cacheKey = `cep_data_${cleanCep}`;
        const cached = sessionStorage.getItem(cacheKey);
        
        let data;
        
        if (cached) {
          data = JSON.parse(cached);
        } else {
          const response = await fetch(`https://viacep.com.br/ws/${cleanCep}/json/`);
          data = await response.json();
          if (!data.erro) {
            sessionStorage.setItem(cacheKey, JSON.stringify(data));
          }
        }

        if (data.erro) {
          throw new Error('CEP não encontrado.');
        }

        // Sucesso
        const city = data.localidade;
        const state = data.uf;

        // Salva dados
        localStorage.setItem('shopify_customer_cep', cleanCep);
        localStorage.setItem('shopify_customer_city', city);
        localStorage.setItem('shopify_customer_state', state);
        
        // Atualiza variáveis locais
        currentCep = cleanCep;
        currentCity = city;
        currentState = state;

        // Atualiza UI
        updateDisplay(city, state);
        toggleModal(true); // Fecha modal

        // Dispara evento para outros scripts (ex: atualizar frete no carrinho)
        if (shouldDispatch) {
            document.dispatchEvent(new CustomEvent('cep_updated', { 
              detail: { cep: cleanCep, city: city, state: state, source: 'global-cep-field' } 
            }));
        }

        // Tenta atualizar atributo do carrinho (se a função existir ou via fetch)
        updateCartAttributes(cleanCep, city, state);

      } catch (err) {
        console.error(err);
        showError('CEP inválido ou não encontrado.');
      } finally {
        setLoading(false);
      }
    }

    function updateCartAttributes(cep, city, state) {
      // Tenta usar a API padrão do Shopify para atualizar atributos do carrinho
      // Isso é útil para persistir a informação no checkout
      fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          attributes: {
            'CEP': cep,
            'Cidade': city,
            'Estado': state
          }
        })
      }).catch(e => console.warn('Erro ao atualizar atributos do carrinho', e));
    }

    function clearLocation() {
      localStorage.removeItem('shopify_customer_cep');
      localStorage.removeItem('shopify_customer_city');
      localStorage.removeItem('shopify_customer_state');
      
      currentCep = '';
      currentCity = '';
      currentState = '';
      
      input.value = '';
      updateDisplay('', '');
      toggleModal(true);
      
      // Atualiza carrinho para limpar
      updateCartAttributes('', '', '');
      
      document.dispatchEvent(new CustomEvent('cep_updated', { 
        detail: { cep: null, city: null, state: null } 
      }));
    }

    // --- Event Listeners ---
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleModal();
    });

    closeMobile.addEventListener('click', () => toggleModal(true));
    backdrop.addEventListener('click', () => toggleModal(true));

    // Fechar ao clicar fora (desktop)
    document.addEventListener('click', (e) => {
      if (!component.contains(e.target) && modal.classList.contains('active')) {
        toggleModal(true);
      }
    });

    input.addEventListener('input', (e) => {
      let val = e.target.value;
      e.target.value = formatCep(val);
      if (errorMsg.textContent) clearError();
    });

    input.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        fetchCepData(input.value);
      }
    });

    submitBtn.addEventListener('click', () => {
      fetchCepData(input.value);
    });

    clearBtn.addEventListener('click', (e) => {
      e.preventDefault();
      clearLocation();
    });

    // Escuta atualizações externas (ex: calculadora da página de produto)
    document.addEventListener('cep_updated', (e) => {
      const cep = e.detail.cep;
      const source = e.detail.source;
      
      // Ignora se a atualização veio daqui mesmo
      if (source === 'global-cep-field') return;

      if (cep) {
         // Atualiza sem disparar novo evento para evitar loops
         fetchCepData(cep, false);
      } else if (cep === null) {
          // Se cep for null, limpa (mas cuidado com loops aqui também)
          // clearLocation dispara evento, então precisamos de flag lá também?
          // clearLocation não aceita flag ainda, mas podemos ignorar por enquanto
      }
    });

    // Inicializa
    init();
  });
</script>
